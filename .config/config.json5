{
  "keybindings": {
    "Normal": {
      "<q>": "Quit", // Quit the application
      "<Ctrl-d>": "Quit", // Another way to quit
      "<Ctrl-c>": "Quit", // Yet another way to quit
      "<Ctrl-z>": "Suspend", // Suspend the application
      "<i>": "InputMode",
      "<g>": "Graph",
      "<d>": "Dump",
      "<f>": "Interface",
      "<c>": "Clear",
      "<s>": "Scan",
      "<e>": "Export",
      "<up>": "Up",
      "<down>": "Down",
      "<left>": "Left",
      "<right>": "Right",
      "<Tab>": "Tab",
      // Vim-style navigation
      "<h>": "Left",
      "<j>": "Down",
      "<k>": "Up",
      "<l>": "Right",
      // Alternative quit keys (macOS-friendly; Ctrl-c/d/z are consumed by the OS)
      "<Alt-q>": "Quit",
      "<F10>": "Quit",
      "<1>": "JumpDiscovery",
      "<2>": "JumpPackets",
      "<3>": "JumpPorts",
      "<4>": "JumpSniffer",
    },
    "Input": {
      "<Esc>": "NormalMode"
    }
  }
}
